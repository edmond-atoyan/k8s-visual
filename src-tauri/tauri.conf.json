{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K8s Visual",
  "version": "1.0.0",
  "identifier": "io.github.k8svisual",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "K8s Visual",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "category": "DeveloperTool",
    "shortDescription": "See your Kubernetes cluster as a living diagram",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
